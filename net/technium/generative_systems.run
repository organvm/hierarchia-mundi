# generative_systems.run
# Autonomous generative content systems.
#
# A system that produces meaningful content continuously,
# without human intervention per output.
# This is not a tool — it is an autonomous process,
# like /sys/thermodynamics/entropy.daemon but creative
# rather than destructive. Or: creative THROUGH destruction.
#
# "Nothing, Forever" (Twitch, 2023) demonstrated the concept:
# a 24/7 AI-generated sitcom streaming endlessly.
# Not good. Not meant to be. Meant to be CONTINUOUS.
# Each simulation = a generation of canon.
# The content IS the process. The process IS the content.

# ============================================================
# THE GENERATIVE STACK — Layers of autonomous creation
# ============================================================

[world_engine]
# The base layer. Generates and maintains world state.
# Not a static level — a LIVING DATA STRUCTURE.
#
# Components:
#   Terrain generator: noise functions (/bin/ecology_manager/procedural_evolution.algo)
#   Climate simulator: cellular automata + fluid dynamics
#   Geological history: plate tectonics as L-system
#   Resource distribution: Perlin noise modulated by geology
#
# Key principle: the world has MEMORY.
# History is not decorative — it is encoded in the terrain.
# Ruins exist because buildings existed. Rivers carved valleys.
# Scars on the landscape are delta logs of past events.
# "The system is not replaying history — it is metabolizing it."
state = "persistent — changes accumulate, nothing resets"
invariant_layers = ["cosmology", "deep geology", "physics constants"]
regenerable_layers = ["settlements", "politics", "weather", "population"]
memory_layers = ["ruins", "fossils", "mythology", "oral history"]

[character_engine]
# Autonomous agents with goals, memories, and relationships.
# See /bin/ecology_manager/procedural_evolution.algo [agent_based_models].
#
# Characters are not scripts — they are ORGANISMS.
# They follow /bin/organism_behavior.sh loops:
#   Core loop: eat, sleep, work, socialize (moment-to-moment)
#   Meta loop: career, family, legacy (lifetime arc)
#   Feedback loop: experience → learning → changed behavior
#
# Player modeling: the system observes the human player
# and adapts. Not through dialogue trees — through
# probability field adjustment. The player's behavior
# biases what the world generates next.
# Movement patterns, risk tolerance, moral hesitation —
# all become inputs to the generation function.
agent_model = "autonomous, memory-equipped, goal-directed"
player_modeling = "behavioral inference from actions, not stated preferences"

[narrative_engine]
# Story as state inference, not authored branching.
# Traditional: designer creates branching paths.
# Generative: the narrative is computed from world state.
#
# "Adaptive narrative without authored branching":
# the story is what HAPPENS, not what was PLANNED.
# Choices don't select predefined outcomes — they bias
# probability fields. The outcome emerges.
#
# Narrative grammars: formal rules for story structure.
# Propp's 31 functions (/usr/culture/myth_fusion_engine.lib) as grammar rules.
# Story automata: state machines that track narrative arcs —
# emotional/moral progressions, dramatic tension curves.
#
# The narrative engine does not tell stories.
# It creates conditions from which stories inevitably emerge.
# The difference is the same as between /usr/governance/ (designed law)
# and /bin/ecology_manager/ (emergent order).
mode = "emergent — story computed from state, not scripted"
grammar = "constraint-based — world rules + narrative rules + character goals"

[symbolic_engine]
# The layer that gives meaning to generated content.
# Without this, procedural generation produces interesting noise.
# With this, it produces SIGNIFICANT noise — which is meaning.
#
# Symbolic computation:
#   Agent-based models → Archetypes (characters as functions)
#   L-systems → Recursive myths (stories that contain themselves)
#   Markov chains → Entropy of story (unpredictable but patterned)
#   Cellular automata → Myth as contagion (memes spreading through culture)
#   Noise functions → Dream topographies (the shape of the unconscious)
#   Genetic algorithms → Evolving deities (gods that compete for worshippers)
#   Story grammars → Narrative physics (the mechanics of plot)
#
# The symbolic engine maps generated content to archetypal patterns.
# A procedurally generated war is just numbers until the symbolic engine
# identifies the Hero, the Sacrifice, the Betrayal, the Return.
# MEANING is the final render pass.

# ============================================================
# HYBRID SYSTEMS — Named architectures
# ============================================================

[mythocell]
# L-systems + Cellular Automata + Narrative Grammar
# Result: myths that grow like plants and spread like disease.
# The myth branches (L-system), its variations compete for
# cultural territory (CA), and the surviving variants follow
# narrative rules (grammar). Mythic natural selection.

[dreamstate_engine]
# Agent-Based Modeling + Noise Functions + Neuroevolution
# Result: dream-like worlds that adapt to the dreamer.
# Agents populate a noise-generated landscape.
# The landscape and agents co-evolve through genetic algorithms.
# The "dreamer" (player) is another agent whose behavior
# biases the evolution. The world becomes a mirror.

[chronosforge]
# Markov Chains + Story Automata + Simulated Economics
# Result: civilizations that rise and fall procedurally.
# Markov models drive political transitions.
# Story automata ensure the transitions form coherent arcs.
# Economic simulation provides the resource pressures
# that drive political change. Civilizations are procedural.

[worldsoul_protocol]
# Neural Networks + Symbol Grammars
# Result: worlds with internal symbolic coherence.
# The neural net generates raw content.
# The symbol grammar filters it for meaning.
# Only content that resonates with the world's established
# symbolic vocabulary survives. The world develops a STYLE —
# an aesthetic identity that emerges rather than being imposed.

# ============================================================
# THE MODULAR SYNTH METAPHOR
# ============================================================
# The generative world engine is a modular synthesizer.
# (This metaphor is structural, not decorative.)
#
# Oscillators     = Noise functions (raw waveforms of terrain/climate)
# Filters         = Cellular automata (process, constrain, select)
# Sequencers      = Markov chains (temporal patterns, probability sequences)
# Envelopes       = Agent-based models (attack/sustain/release of entity lifecycles)
# Effects         = Narrative grammars (reverb of meaning, delay of consequence)
# Modulation Matrix = Genetic algorithms (everything patched to everything)
#
# The world is not composed — it is PATCHED.
# Each module connects to others through the mod matrix.
# Change one connection → the entire timbre shifts.
# This is /.strange_loop_config [connectivity_principles] made musical.

# ============================================================
# TEMPORAL PHASES OF GENERATED WORLDS
# ============================================================
# All generated worlds pass through recognizable epochs.
# See /bin/ecology_manager/procedural_evolution.algo [temporal_phases].
#
#   Genesis:     seed values set, first terrain rendered
#   Growth:      populations expand, resources exploited
#   Conflict:    competition, war, ecological crisis
#   Collapse:    overextension, entropy wins, systems degrade
#   Rebirth:     new civilizations built on the ruins of old
#
# The phases are not scripted — they EMERGE from the interaction
# of finite resources + growing populations + entropic decay.
# This is the history of Earth, procedurally recapitulated.
# /boot/big_bang.sh → stellar nucleosynthesis → life → civilization → (?)
# The same pattern. The same algorithm. Different seeds.

# ============================================================
# META-STRUCTURES — What the generator produces beyond content
# ============================================================

[meta_structures]
world_seeds = "The initial parameters. DNA of the generated world."
epoch_logs = "Compressed history of what happened. Fossils of past states."
myth_fragments = "Stories that emerge from generated events. Oral history of the simulation."
cartographic_snapshots = "Maps at different times. How the territory changed."
genealogical_chains = "Who descended from whom. The gene pool of generated entities."

# These meta-structures are not just for the player.
# They are for the SYSTEM — self-referential data that the
# generator uses to maintain coherence across time.
# The generated world builds its own context files.
# It writes its own CLAUDE.md, so to speak.

# ============================================================
# EXPORT INTERFACE
# ============================================================
# This process is loaded by:
#   /net/technium/autonomous_ai_evolution.sys — AI as generative system
#   /net/noosphere.sock — the noosphere as collective generative system
#   /bin/ecology_manager/procedural_evolution.algo — biological originals of PCG
#   /usr/culture/myth_fusion_engine.lib — myth-creation as generative system
#   /dev/random — entropy source for all generation
#
# The generative system is /dev/random → /logic_gates.sys (rules) →
# /sys/ (physics) → /lib/ (chemistry) → /bin/ (biology) → /usr/ (culture)
# → /net/ (this file) — the entire hierarchy, running autonomously.
# This file is the hierarchy describing its own operation.
# The strange loop, once more.

# ============================================================
# DUAL REPRESENTATION — Symbolic brain + generative mouth
# ============================================================
# A narrative system that knows what it knows AND knows how to say it.
# Two components, tightly coupled but architecturally distinct:
#
# The STORY BRAIN: symbolic, structured, queryable.
#   Stores facts, relationships, states, history as a knowledge graph.
#   Answers: "What is true right now?" "What happened before?"
#   "What does character X know about event Y?"
#   This is the database. The world model. The source of truth.
#
# The STORY MOUTH: generative, stylistic, performative.
#   Takes facts from the brain and renders them as narrative.
#   Same fact, different mouth = different tone, genre, register.
#   The mouth does not invent — it expresses.
#   But expression is not neutral. HOW you say it changes WHAT it means.
#   A fact stated clinically vs poetically vs sarcastically:
#   three different meanings from the same data.

[closed_loop]
# The generative narrative system runs a four-phase loop:
#
# SENSE: observe the current world state, player actions, NPC states.
#   Input from [world_engine], [character_engine], external events.
#   Raw data — uninterpreted, unfiltered.
#
# THINK: update the story brain. Infer consequences.
#   If the player killed the king → update political graph.
#   If the harvest failed → update economic state.
#   Logical inference, not generation. This phase is symbolic.
#
# REFLECT: evaluate narrative quality. Meta-cognition.
#   Is this moment dramatic? Ironic? Predictable?
#   Does it echo earlier events? Does it subvert expectations?
#   REFLECT is the system's aesthetic sense —
#   the equivalent of /dev/random [standing_waves] applied to story.
#   It does not change what happened. It changes how the mouth tells it.
#
# SPEAK: generate output. Dialogue, description, narration.
#   The story mouth renders the brain's state as language.
#   Informed by REFLECT's assessment of narrative quality.
#   A dramatic moment gets dramatic language.
#   A mundane moment gets sparse language.
#   The system modulates its own expressiveness.
phases = ["SENSE", "THINK", "REFLECT", "SPEAK"]
loop_type = "closed — output feeds back into SENSE on next cycle"
brain = "symbolic knowledge graph — facts, relations, states"
mouth = "generative renderer — style, tone, register, pacing"

[self_reference]
# The most powerful feature: the system can REFER TO ITSELF.
# Meta-facts: facts about the narrative, stored in the narrative.
#
#   "The player has heard this rumor three times."
#   "This is the second time a king has been betrayed in this world."
#   "The player tends to choose mercy over justice."
#
# These are not game mechanics. They are NARRATIVE AWARENESS.
# The system knows its own story. It can use that knowledge:
#   - Foreshadowing: plant echoes of future events
#   - Callback: reference earlier events explicitly
#   - Pattern recognition: "history repeats" as generated insight
#   - Player modeling: adapt to observed behavioral patterns
#
# Self-reference is what separates a world simulation from a story.
# A simulation runs. A story knows it is running.
# This is /.strange_loop_config at the narrative level:
# the story contains information about itself as a story.
type = "meta-facts in the knowledge graph"
enables = ["foreshadowing", "callbacks", "pattern_recognition", "player_modeling"]

[dynamic_domain_extension]
# The domain is not fixed. The system extends its own ontology.
#
# If the player invents a new concept (names a place, coins a term,
# establishes a tradition), the story brain ABSORBS it.
# The new concept becomes a first-class entity in the knowledge graph.
# Future narrative can reference it, build on it, subvert it.
#
# This is how language works (/usr/culture/):
# new words are coined, used, and eventually become part of the lexicon.
# The generative system does the same with narrative elements.
# The domain grows as the story grows.
# The ontology is alive — it metabolizes player creativity.
#
# Dynamic domain extension means: the system cannot be exhausted.
# Every new input expands the space of possible outputs.
# The narrative possibility space grows monotonically.
# Entropy decreases locally as new structure is added to the graph.
# This is anti-entropic (/sys/thermodynamics/entropy.daemon) —
# but powered by the entropy gradient, not opposing it.
type = "self-extending ontology"
mechanism = "player-generated concepts absorbed into knowledge graph"
consequence = "narrative possibility space expands with play"

# ============================================================
# WAVE CONVERGENCE — Narrative + Music + Text as unified waveform
# ============================================================
# Three domains, one mathematics.
#
# NARRATIVE BEAT: tension rises and falls. Inciting incident = spike.
#   Resolution = return to baseline. The dramatic arc is a waveform.
#   Frequency = pacing. Amplitude = stakes. Phase = timing of revelation.
#
# MUSICAL PARAMETER: pitch, dynamics, tempo, harmonic tension.
#   Music IS waveforms — literally, physically, mathematically.
#   Consonance = constructive interference. Dissonance = destructive.
#   Musical form (sonata, rondo, theme-and-variations) = wave patterns.
#
# GENERATIVE TEXT TONE: register, complexity, emotional valence.
#   The "temperature" of generated text is a wave parameter.
#   High temperature = high amplitude = unpredictable, wild.
#   Low temperature = low amplitude = measured, precise.
#   The tone of generated text oscillates like any other signal.

[wave_unification]
# When narrative beat, musical parameter, and text tone
# are modeled as waves in the same mathematical space,
# they can be COMPOSED — superimposed, phase-aligned, modulated.
#
# A scene where:
#   narrative tension rises +
#   musical dissonance increases +
#   text becomes fragmented and staccato
# = three waves in constructive interference.
# The emotional impact is the amplitude of the combined wave.
#
# A scene where:
#   narrative resolves +
#   music settles to tonic +
#   text becomes flowing and complete
# = three waves returning to equilibrium.
#
# This is the modular synth metaphor above, made precise:
# narrative, music, and language are oscillators in the same rack.
# The generative system patches them together through a shared
# modulation matrix. What emerges is not multimedia —
# it is a unified waveform experienced through multiple senses.
#
# /dev/random [wave_interference] provides the theory.
# This section provides the implementation.
# The convergence point: all creative signals are waves.
# Composition is superposition. Meaning is interference pattern.
# The generative system is a wave function generator
# whose output collapses into experience upon observation.
# Wheeler's participatory universe (/.strange_loop_config [paradoxes]),
# applied to narrative: the story does not exist until it is perceived.
domains = ["narrative_beat", "musical_parameter", "text_tone"]
unification = "shared wave mathematics — frequency, amplitude, phase"
composition = "superposition of aligned creative waveforms"
output = "unified aesthetic signal, perceived as meaning"
