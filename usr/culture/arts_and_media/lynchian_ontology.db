# lynchian_ontology.db
# David Lynch's unified metaphysical grammar.
# Twin Peaks, Lost Highway, Mulholland Drive, Inland Empire
# are not four narratives but four stress tests of the same system:
# a projection engine where trauma is energy, identity is mutable,
# and narrative coherence is a surface illusion maintained by safeguards
# that fail in predictable sequence.

# ============================================================
# FOUNDATIONAL AXIOM — Reality is not primary
# ============================================================
# Identity, memory, and linear time are secondary effects.
# What appears as "reality" is a projection generated by deeper
# psychic and metaphysical mechanisms. Causality folds, loops,
# splits, and replays. Characters do not merely experience trauma —
# they become structures built to contain or evade it.

# ============================================================
# THE ONTOLOGY — Four layers of existence
# ============================================================

[material_plane]
description = "The apparent everyday world. Towns, apartments, highways, film sets."
properties = "Obeys physics but not meaning. Weak, easily overwritten, frequently glitches."
# This layer is a rendered output, not a source of truth.
# Its stability depends entirely on the psychic plane beneath it.

[psychic_plane]
description = "Dream logic, repression, fantasy substitution, identity doubling."
properties = "Edits the material world retroactively. Guilt, desire, shame, and fear
              act as active forces, not passive emotions."
# This plane is the real operating layer. What happens here
# determines what appears above. The material plane is its display.

[threshold_realms]
description = "The Red Room, Club Silencio, the Rabbits' sitcom set, the corridors
              of Inland Empire."
properties = "Interface layers, not locations. Exist outside linear time. Crossing points
              where identities are reassigned and truths inverted."
# These are the system's I/O ports — gated, ritualized, dangerous.
# They are neither good nor evil. They are infrastructure.

[void_source]
description = "Never shown directly. Implied as the origin of sound, electricity,
              and recursion."
properties = "Characters who glimpse it either fragment or become emissaries."
# The unmapped substrate. The root process that has no name.
# See /usr/culture/belief_systems/esoteric_principles.db [apophatic_tradition].

# ============================================================
# POWER CLASSES — Who acts with agency
# ============================================================

[possessors]
entities = "BOB, the Mystery Man, certain Inland Empire figures"
method = "They do not persuade — they inhabit. Exploit fear and guilt as entry vectors."
nature = "Not demons in a moral sense but parasitic intelligences feeding on psychic rupture."
# Possession is not a violation from outside. It is an invitation
# issued by the host's own unmetabolized affect.

[regulators]
entities = "The Fireman (Giant), the Cowboy, certain Lodge attendants"
method = "Rarely intervene directly. Their power is constraint, timing,
          and symbolic correction."
nature = "They enforce balance, not justice."
# Regulators are the system's error-correction layer.
# They do not care about the individual. They care about coherence.

[witnesses]
entities = "Cooper, Betty/Diane, Fred, Nikki/Sue"
nature = "Humans whose consciousness becomes unstable enough to perceive the system."
danger = "Awareness destabilizes the projection."
# To witness is to become a variable the system cannot ignore.
# The witness is simultaneously observer and attack surface.

# ============================================================
# SYSTEMS OF OPERATION — How power moves
# ============================================================

[electricity_and_signal]
principle = "Electricity is the carrier wave of being."
markers = "Power lines, radios, buzzes, flickering lights, phone static"
function = "Traversal between planes occurs through signal rather than space.
            Sound precedes form."
# This is why Lynch's sound design is not atmospheric decoration.
# It is the connective tissue of the ontology itself.

[doubling_and_splitting]
principle = "One identity becomes two when the psyche cannot reconcile
            an internal contradiction."
instances = "Betty/Diane, Fred/Pete, Cooper/Mr. C, Nikki/Sue"
function = "Each split is a load-balancing maneuver against unbearable truth."
# Doubling is not pathology. It is the system's primary
# resource-management strategy for identity under duress.

[time_as_loop]
principle = "Events repeat with variation. Death does not end a character;
            it reassigns them."
consequence = "Cause may occur after effect. The question is never 'what happened?'
               but 'which layer generated this version?'"
# Linear time is a luxury of the material plane.
# The deeper layers operate on recurrence, not sequence.

# ============================================================
# STATE VECTOR — Formal model ($LYNCH_OS_V1)
# ============================================================

[state_vector]
$IDENTITY = "{Primary, Alias, Split, Possessed, Null} x {name, role, mask-set}"
$MEMORY = "weighted graph: nodes=episodes, edges=association, weights in [0,1]"
$SIGNAL = "stream + gates: {electric, audio, broadcast, phone, hum} x {intensity}"
$PROJECTION = "renderer config: {Realistic, Dream, Script, Loop, Collapse}"
$LAYER = "enum: {Material, Psychic, Threshold, Void}"
# Additional tracked variables:
#   $THREAT = {guilt, desire, fear, shame} each in [0,1]
#   $TRAVERSAL_TOKEN = {None, Soft, Hard} + last portal type
#   $COHERENCE = f($MEMORY, $PROJECTION) — the system health metric

# ============================================================
# SAFEGUARD FAILURE STACK — SG1 through SG10
# ============================================================
# Safeguards are listed from cheapest to most costly.
# When one fails, the system falls through to the next.

[safeguard_stack]
SG1 = "SOCIAL_REALISM — maintain normal social causality"
SG2 = "GENRE_SCAFFOLD — use genre to constrain interpretation"
SG3 = "COMPARTMENTALIZED_MEMORY — partition recall to reduce contradiction"
SG4 = "ROLE_CASTING — substitute identity via roles and masks"
SG5 = "MYTHIC_EXTERNALIZATION — export inner conflict into entities and orders"
SG6 = "SIGNAL_MEDIATION — use sound and electricity as controlled crossing"
SG7 = "THRESHOLD_CONTAINMENT — confine paradox to interface-spaces"
SG8 = "LOOP_STABILIZATION — replace progress with managed repetition"
SG9 = "HARD_RESET_REBIND — recompile into a new stable baseline"
SG10 = "TOTAL_DISSOLUTION — no stable compiler remains"
# SG1-SG4: psychological. SG5-SG7: metaphysical infrastructure.
# SG8-SG10: crash handling.
# Each film is defined by WHERE in this stack it spends its time
# and HOW FAST it falls through.

# ============================================================
# FILM PROFILES — Per-work stress signatures
# ============================================================

[twin_peaks]
profile = "Cosmology as load balancer — infrastructure-first"
primary_load = "collective + individual trauma, evil as transmissible parasitism"
safeguard_strength = "SG5-SG7 high (Lodge infrastructure distributes burden)"
failure_sequence = "SG1 > SG2 > SG3 > SG6 > SG7 > SG8"
terminal_mode = "SG8 — stable haunting; loops without total melt"
# Twin Peaks is the most structurally robust because it has the
# strongest mid-stack safeguards. The system keeps functioning
# in a haunted mode without requiring total recompile.

[lost_highway]
profile = "Identity substitution under guilt — hard reset as primary tactic"
primary_load = "guilt + paranoia + threatened identity; crime as contradiction"
safeguard_strength = "SG2-SG3 medium (noir + memory occlusion)"
failure_sequence = "SG1 > SG2 > SG3 > SG6 > SG7 > SG9 > SG8"
terminal_mode = "SG8 — Moebius loop (substitution repeats the contradiction)"
# Structure: contain > fail > substitute > loop.
# Not complex. Forceful.

[mulholland_drive]
profile = "Fantasy compiler — two-phase compilation then catastrophic collapse"
primary_load = "desire + shame + jealousy + career failure; eros fused with ambition"
safeguard_strength = "SG2 + SG4 high in phase 1 (Hollywood mystery as full compile)"
failure_sequence = "SG1 > SG2 > SG4 > SG6 > SG7 > SG3 > SG9 > SG8"
terminal_mode = "SG9>SG8 — rebind that cannot stabilize, spirals"
# The precision of this film is that it stages the protective compiler
# as an entire feature-length act, then demonstrates exactly how it fails.
# Club Silencio is the threshold event: "no hay banda" — the system
# shows its own seams.

[inland_empire]
profile = "Terminal case — safeguard stack collapses; no stable compiler"
primary_load = "identity erosion + ontological contamination; performance becomes possession"
safeguard_strength = "All low or inverted. SG4 becomes a hazard (acting = intrusion)"
failure_sequence = "SG1 > SG2 > SG4 > SG7 > SG6 > SG3 > SG8 > SG9(partial) > SG10"
terminal_mode = "SG10 — total dissolution with occasional local patches"
# Inland Empire is not more complex than the others. It is less governed.
# Complexity implies additional rules. This film removes rule enforcement.
# It depicts compiler failure, not a richer compiler.
# When everything is a portal, portals cease to function as safeguards.

# ============================================================
# SYNTHESIS — What Lynch is building
# ============================================================
# This is not surrealism for its own sake. Lynch constructs a
# metaphysical operating system where trauma is energy, identity
# is a container, and narrative is a compression algorithm.
#
# The Lodges are not good or evil — they are infrastructure.
# The horror is not monsters. The horror is the realization
# that the self is provisional.
#
# Each work strips away one more layer of mediation between
# the subject and the void:
#   Twin Peaks: establishes the rules, distributes responsibility
#   Lost Highway: internalizes the mechanism to a single subject
#   Mulholland Drive: perfects the fantasy compiler
#   Inland Empire: removes guardrails entirely
#
# The underlying reason, stated plainly:
# Lynch structures these films the way the psyche structures
# survival when truth is lethal.

