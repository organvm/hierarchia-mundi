# architecture_types.db
# Typologies of structure: physical, digital, symbolic, social.
#
# Architecture is the art of organizing space for human purpose.
# But "space" is not limited to physical dimensions.
# Software has architecture. Societies have architecture.
# Cosmologies have architecture. The mind has architecture.
# This database catalogs the structural patterns that recur
# across all domains where organization meets intention.

# ============================================================
# PHYSICAL / BUILT ARCHITECTURE
# ============================================================
# Structures that organize physical space for human habitation,
# work, worship, defense, and transit.

[building_types]

residential = ["single-family house", "duplex", "apartment", "townhouse",
               "manor", "palace", "yurt", "longhouse", "houseboat",
               "commune", "dormitory"]
# Shelter is the first built structure.
# The form of housing determines the form of society:
# single-family sprawl → car dependency → suburban isolation.
# Apartment density → walkability → urban vitality.
# See /usr/governance/local_zoning_laws.txt — zoning IS housing policy.

civic = ["courthouse", "city hall", "library", "post office",
         "fire station", "police station", "embassy", "parliament"]
# Buildings that house /usr/governance/ processes.
# The architecture of a courthouse communicates: here, power is formal.
# The architecture of a library communicates: here, knowledge is free.

religious = ["temple", "church", "mosque", "synagogue", "pagoda", "shrine"]
# Buildings that house /usr/culture/belief_systems/.
# The Gothic cathedral is theology in stone: vertical aspiration,
# light as divine presence, the nave as community vessel.
# Every religious building is a model of cosmology made habitable.

commercial = ["market", "office", "factory", "warehouse", "mall",
              "bank", "exchange"]
# Buildings that house /usr/economy/ processes.
# The open-plan office is a theory of work made spatial.
# The stock exchange is /net/technium/global_markets_algo.run made architectural.

fortified = ["castle", "fortress", "bunker", "city wall", "watchtower",
             "military base", "nuclear silo"]
# Buildings that resist entropy (/sys/thermodynamics/) by force.
# The castle is a negative-feedback loop in stone:
# attack → wall → repulsion → stability.

transitory = ["airport", "train station", "bus terminal", "port", "bridge"]
# Buildings that facilitate movement between other buildings.
# The airport is /usr/infrastructure/tcp_ip_stack/ in physical form:
# routing, queuing, protocol compliance, throughput optimization.

[room_types]
# Rooms are the cells of architectural organisms.
# Each room type has a narrative function as well as a practical one.

private = ["bedroom", "bathroom", "study", "closet", "nursery", "attic"]
# Bedroom = vulnerability. Where defenses are lowered.
# Bathroom = transformation. Where the body is maintained and renewed.
# Attic = memory. Where the unused is stored but not discarded.

communal = ["kitchen", "dining room", "living room", "courtyard",
            "hallway", "lobby", "garden", "porch"]
# Kitchen = hidden violence (fire, blades, heat) domesticated for nourishment.
# Hallway = the space between spaces. Transition. The dash in the hyphenated life.

symbolic = ["throne room", "ritual chamber", "dreaming chamber",
            "mirror hall", "time room", "void room",
            "archives of the forgotten", "portal gate room"]
# These exist in mythology and fiction, but map to psychological spaces:
# Throne room = the seat of executive function (prefrontal cortex).
# Ritual chamber = the space where transformation is formalized.
# Archives of the forgotten = the unconscious. Repressed memory.
# Portal gate room = the decision point. The fork() system call.

# ============================================================
# ARCHITECTURAL STYLES — The evolution of built form
# ============================================================

[styles]
# Styles evolve like species (/bin/ecology_manager/natural_selection.cron).
# Each responds to the pressures of its era.

gothic = "Pointed arches, flying buttresses, stained glass. (12th-16th c.)"
# Solution to a structural problem: how to build higher, let in more light.
# The flying buttress redirects lateral force outward and down.
# Engineering achievement dressed as theology.

brutalist = "Raw concrete, massive form, exposed structure. (1950s-1970s)"
# Honest materials. No ornament. The building IS what it IS.
# Social housing as architectural manifesto:
# dignity through strength, not decoration.
# Now either beloved or hated. No one is indifferent.

parametric = "Algorithmically generated forms. Zaha Hadid, Frank Gehry."
# Architecture generated by /bin/ecology_manager/procedural_evolution.algo.
# The architect defines constraints. The computer generates form.
# The result: organic curves impossible to design by hand.
# Nature uses parametric design (reaction-diffusion, L-systems).
# Parametric architecture is biomimicry at the structural level.

deconstructivist = "Fragmented forms, apparent instability. Eisenman, Libeskind."
# The building looks like it is falling apart. On purpose.
# Derrida's deconstruction made spatial: meaning is unstable,
# structure is provisional, certainty is a pretense.
# The architecture OF uncertainty.

# ============================================================
# DIGITAL / SOFTWARE ARCHITECTURE
# ============================================================
# How code is organized. The built environment of computation.

[software]
client_server = "Centralized authority. One server, many clients."
# The feudal model of computing. The server IS the lord.
# Simple, efficient, single point of failure.

microservices = "Distributed. Each service owns its domain."
# The democratic model. No single point of failure.
# But: distributed systems are harder to debug than monarchies.
# CAP theorem: you can have 2 of 3 (consistency, availability, partition tolerance).

event_driven = "Systems communicate through events, not direct calls."
# Loose coupling. Publisher doesn't know subscriber.
# The nervous system is event-driven: neurotransmitters don't know
# which receptors will receive them. The brain doesn't have an API — it has events.

layered = "Presentation → Business Logic → Data Access → Storage."
# The most common pattern. Also the most common trap:
# layers accumulate like geological strata, and like strata,
# they are very difficult to rearrange once deposited.

# ============================================================
# SYMBOLIC / COSMOLOGICAL ARCHITECTURE
# ============================================================
# Structures that model the universe rather than inhabit it.

[symbolic]
mandala = "Concentric circles and squares representing the cosmos."
# Tibetan Buddhism, Hinduism. The mandala IS the universe in miniature.
# Drawing one is meditation. Destroying one is accepting impermanence.

ziggurat = "Stepped pyramid connecting earth to heaven."
# Mesopotamia: the artificial mountain. The axis mundi made of brick.
# Each level a stratum. This filesystem is a digital ziggurat.

labyrinth = "Single path, winding. Not a maze — no dead ends."
# Knossos. Chartres cathedral floor. The path IS the journey.
# You cannot get lost. You can only keep walking.
# The labyrinth is /boot/big_bang.sh → /dev/null: one path, no undo.

tree_of_life = "Kabbalistic: 10 sephiroth connected by 22 paths."
# The Tree of Life is a dependency graph of divine attributes.
# Kether (Crown/Source) → ... → Malkuth (Kingdom/Manifestation).
# This filesystem maps roughly: / → /boot/ → ... → /dev/.
# The Kabbalists were systems architects of the sacred.

# ============================================================
# SOCIAL / POLITICAL ARCHITECTURE
# ============================================================

[social]
panopticon = "Bentham (1791): circular prison where all inmates
              are visible from a central tower, but cannot see the observer."
# Foucault: the panopticon is the model of modern surveillance.
# You behave not because you are watched, but because you MIGHT be.
# Social media is a distributed panopticon: everyone watches everyone.

agoratic = "The Greek agora: open, public, participatory."
# The marketplace of ideas AND goods. Democracy emerged here.
# The internet was supposed to be an agora.
# It became a panopticon + marketplace. The architecture won.

feudal = "Hierarchical. Lord → vassal → serf. Pyramid of obligation."
# The default architecture of power without democratic feedback.
# See /usr/governance/ — the iron law of oligarchy
# says all organizations tend toward feudal architecture.
# Preventing feudalism requires active structural maintenance.

# ============================================================
# CHRONO-FUNCTION — How building types evolve
# ============================================================
# Ancient: temple, fortress, agora. Function: worship, defense, assembly.
# Medieval: cathedral, castle, guild hall. Function: faith, power, craft.
# Industrial: factory, tenement, railroad station. Function: production, housing, transit.
# Modern: skyscraper, suburb, airport. Function: commerce, living, movement.
# Postmodern: mixed-use, adaptive reuse, pop-up. Function: flexibility.
# Speculative: arcology, space habitat, virtual architecture. Function: survival beyond Earth.
#
# The evolution of building types mirrors the evolution of human needs.
# As needs complexify, architecture complexifies.
# As /usr/ grows, /usr/infrastructure/ grows with it.

