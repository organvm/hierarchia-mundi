# /dev/null
# Black holes: data permanently destroyed.
#
# In Unix, /dev/null is the bit bucket — write to it,
# the data vanishes. In reality, /dev/null is where
# information reaches the boundary of physics.

# ============================================================
# BLACK HOLES
# ============================================================
# A region of spacetime where gravity is so strong that
# nothing — not even light — can escape.
# The event horizon is a one-way door.
# Cross it and you are erased from the observable universe.

[formation]
# Stellar black holes: massive star (>25 M☉) collapses at death.
# Supermassive: millions to billions of solar masses. Every galaxy has one.
#   Sagittarius A* (Milky Way center): 4 million M☉
#   M87*: 6.5 billion M☉ (first one photographed, 2019)
# Primordial: possibly formed in the early universe (unconfirmed)

[singularity]
# At the center: a point of infinite density.
# All known physics breaks down.
# General relativity says: singularity.
# Quantum mechanics says: probably not — but we don't have a replacement.
# Resolving this is the prize of quantum gravity.

[information_paradox]
# Hawking (1975): black holes slowly evaporate via Hawking radiation.
# But the radiation is thermal — it carries no information about
# what fell in. The information appears to be destroyed.
#
# Problem: quantum mechanics forbids information destruction.
# Unitarity: the wave function of the universe must be preserved.
#
# Possible resolutions:
#   1. Information is encoded in Hawking radiation (subtle correlations)
#   2. Information is stored on the event horizon (holographic principle)
#   3. Information leaks out via quantum tunneling
#   4. Information is lost (violates quantum mechanics)
#
# Recent developments (Page curve, island formula, 2019-2020)
# suggest option 1+2. Information IS preserved.
# /dev/null is not truly null after all.
# Even the void returns what you thought was destroyed.

[entropy]
# Black hole entropy: S = A/(4·l_P²)
# Proportional to surface area, not volume.
# A stellar black hole has MORE entropy than a star.
# The entropy of the observable universe is dominated
# by supermassive black holes (~10^104 in natural units).
#
# Black holes are the ultimate entropy reservoirs.
# They are where /sys/thermodynamics/entropy.daemon deposits
# the universe's accumulated disorder.
# /dev/null is the entropy sink.

# ============================================================
# WHAT /dev/null TEACHES
# ============================================================
# 1. Boundaries exist. Not everything is recoverable.
# 2. Information may persist even when it appears destroyed.
# 3. The deepest physics lives at the boundary, not the center.
# 4. Even the void has structure.
# 5. The universe is conservative with information —
#    more conservative than we expected.
#
# /dev/null is not the end of the hierarchy.
# It is where the hierarchy meets its own limits
# and discovers that limits are also information.
