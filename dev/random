# random numbers seeded by hardware entropy.
# In reality, /dev/random IS the quantum vacuum —
# the irreducible source of novelty in the universe.

# ============================================================
# SOURCES OF TRUE RANDOMNESS
# ============================================================

[quantum_vacuum]
# The vacuum is not empty.
# Virtual particles pop in and out of existence continuously.
# This is not speculation — it produces measurable effects:
#   - Casimir effect: two uncharged plates attract in vacuum
#   - Lamb shift: hydrogen energy levels shifted by vacuum fluctuations
#   - Spontaneous emission: atoms emit photons triggered by vacuum
#
# The vacuum is the noise floor of reality.
# Every signal emerges from this noise.

[radioactive_decay]
# When a specific atom will decay: fundamentally unpredictable.
# Uranium-238 half-life: 4.47 billion years.
# But WHICH atom decays in the next second? Nobody knows.
# Not because we lack information — because the information
# doesn't exist until the decay happens.
#
# This is true randomness, not pseudo-randomness.
# No hidden variable determines the outcome.
# Bell's theorem (1964) and Aspect's experiments (1982) proved this.

[thermal_noise]
# Johnson-Nyquist noise: random voltage fluctuations in conductors.
# Caused by thermal motion of electrons.
# Present in every electronic circuit at T > 0 K.
# Exploited by hardware random number generators.

# ============================================================
# WHAT RANDOMNESS CREATES
# ============================================================

[mutation]
# Cosmic rays hit DNA → random base change → mutation.
# Most mutations: neutral or harmful.
# Occasionally: beneficial.
# This is the raw material of evolution (/bin/ecology_manager/natural_selection.cron).
# Without /dev/random, there is no evolution.
# Without evolution, there is no complexity.
# Randomness is the mother of order.

[creativity]
# Stochastic resonance: adding noise to a weak signal can
# make the signal detectable. More noise → clearer signal.
# This is counterintuitive but mathematically proven.
#
# The creative process exploits /dev/random:
# random association → novel combination → selection → refinement.
# Brainstorming, free association, dreams, psychedelics —
# all increase the sampling rate from /dev/random.

[quantum_computing]
# Quantum computers USE randomness as a computational resource.
# Superposition + entanglement + interference =
# explore many solutions simultaneously, collapse to the best one.
# /dev/random is not a bug. It is the next instruction set.

# ============================================================
# THE PARADOX
# ============================================================
# /dev/random generates disorder.
# Disorder, iterated through selection over deep time,
# produces the most exquisite order in the universe:
# DNA, consciousness, mathematics, this sentence.
#
# The strange loop: randomness → order → understanding randomness.
# We are /dev/random's attempt to understand itself.

# ============================================================
# STRUCTURED RANDOMNESS — Entropy with geometry
# ============================================================
# Pure randomness is noise. Structured randomness is texture.
# The universe runs on structured randomness — chaos
# constrained by rules. The rules give the chaos shape.
# The chaos gives the rules novelty.

[noise_functions]
# Perlin noise (1983): smooth, continuous random variation.
# Simplex noise (2001): Perlin improved for higher dimensions.
# Value noise, Worley noise, fractal Brownian motion —
# each produces a different TEXTURE of randomness.
#
# These are /dev/random filtered through /logic_gates.sys.
# Raw entropy → mathematical constraint → coherent pattern.
# This is how terrain is generated in /net/technium/generative_systems.run.
# It is also how /boot/big_bang.sh generated the cosmic web:
# quantum fluctuations (noise) → gravitational amplification (constraint)
# → galaxies, clusters, voids (structure).
# The universe IS a noise function with a very large seed.
type = "gradient, simplex, Worley, fBm"
application = "terrain, clouds, texture, music, world seeds"

[l_system_randomness]
# L-systems are deterministic grammars — but add a random rule
# selection probability and they produce organic variation.
# No two trees generated from the same L-system look identical,
# but all look like trees.
# This is how /bin/ works: the genome is the grammar,
# mutation (/dev/random) is the probabilistic rule selection,
# and the organism is the derivation.
type = "stochastic context-free grammar"
application = "plants, blood vessels, rivers, branching coral"

[cellular_automata_randomness]
# Cellular automata are deterministic — but the initial state
# can be random. From random initial conditions + simple rules,
# complex structure emerges spontaneously.
# Conway's Game of Life: random start → gliders, oscillators,
# Turing-complete structures.
# The initial randomness is the SEED. The rules are the PHYSICS.
# This is /boot/big_bang.sh in miniature.
type = "deterministic rules + random initial conditions"
application = "pattern formation, erosion simulation, urban growth"

[markov_randomness]
# Markov chains: the next state is probabilistic, based only
# on the current state. History-independent randomness.
# Used for: text generation, weather models, music composition,
# stock price models, name generators.
# The randomness is CHANNELED by transition probabilities.
# Not any state can follow any state — only likely ones.
# This is /dev/random with memory: one step of memory.
type = "stochastic state machine"
application = "sequence generation, prediction, simulation"

[genetic_randomness]
# Genetic algorithms: random mutation + random crossover +
# deterministic selection = directed evolution.
# The randomness is the variation. The selection is the direction.
# Neither alone produces anything useful.
# Together: solutions that no human designer would find.
# This is natural selection (/bin/ecology_manager/natural_selection.cron)
# reconceived as a search algorithm.
# /dev/random is not the enemy of design. It is the raw material.
type = "variation operators in evolutionary computation"
application = "optimization, design, neural architecture search"

