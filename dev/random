# /dev/random
# True quantum randomness generator.
#
# In Unix, /dev/random provides cryptographically secure
# random numbers seeded by hardware entropy.
# In reality, /dev/random IS the quantum vacuum —
# the irreducible source of novelty in the universe.

# ============================================================
# SOURCES OF TRUE RANDOMNESS
# ============================================================

[quantum_vacuum]
# The vacuum is not empty.
# Virtual particles pop in and out of existence continuously.
# This is not speculation — it produces measurable effects:
#   - Casimir effect: two uncharged plates attract in vacuum
#   - Lamb shift: hydrogen energy levels shifted by vacuum fluctuations
#   - Spontaneous emission: atoms emit photons triggered by vacuum
#
# The vacuum is the noise floor of reality.
# Every signal emerges from this noise.

[radioactive_decay]
# When a specific atom will decay: fundamentally unpredictable.
# Uranium-238 half-life: 4.47 billion years.
# But WHICH atom decays in the next second? Nobody knows.
# Not because we lack information — because the information
# doesn't exist until the decay happens.
#
# This is true randomness, not pseudo-randomness.
# No hidden variable determines the outcome.
# Bell's theorem (1964) and Aspect's experiments (1982) proved this.

[thermal_noise]
# Johnson-Nyquist noise: random voltage fluctuations in conductors.
# Caused by thermal motion of electrons.
# Present in every electronic circuit at T > 0 K.
# Exploited by hardware random number generators.

# ============================================================
# WHAT RANDOMNESS CREATES
# ============================================================

[mutation]
# Cosmic rays hit DNA → random base change → mutation.
# Most mutations: neutral or harmful.
# Occasionally: beneficial.
# This is the raw material of evolution (/bin/ecology_manager/natural_selection.cron).
# Without /dev/random, there is no evolution.
# Without evolution, there is no complexity.
# Randomness is the mother of order.

[creativity]
# Stochastic resonance: adding noise to a weak signal can
# make the signal detectable. More noise → clearer signal.
# This is counterintuitive but mathematically proven.
#
# The creative process exploits /dev/random:
# random association → novel combination → selection → refinement.
# Brainstorming, free association, dreams, psychedelics —
# all increase the sampling rate from /dev/random.

[quantum_computing]
# Quantum computers USE randomness as a computational resource.
# Superposition + entanglement + interference =
# explore many solutions simultaneously, collapse to the best one.
# /dev/random is not a bug. It is the next instruction set.

# ============================================================
# THE PARADOX
# ============================================================
# /dev/random generates disorder.
# Disorder, iterated through selection over deep time,
# produces the most exquisite order in the universe:
# DNA, consciousness, mathematics, this sentence.
#
# The strange loop: randomness → order → understanding randomness.
# We are /dev/random's attempt to understand itself.
