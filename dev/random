application = "prompt engineering, generative text, image synthesis"

# ============================================================
# BIOLOGY AS CODE — The Prometheus problem
# ============================================================
# Prometheus stole fire from the gods and gave it to humans.
# The myth is not about fire. It is about TECHNIQUE.
# Fire is the first technology — energy externalized,
# controlled, made transferable. Technique-transfer.
#
# But Prometheus is punished. Why?
# Because technique without care is dangerous.
# Fire warms and fire burns. The tool is indifferent.
# Zeus's punishment is not revenge — it is a systems warning:
# capability without wisdom produces suffering.

[analog_vs_digital]
# Biology is analog. DNA is digital.
# This is the deepest tension in living systems.
#
# Analog: continuous, gradient, lossy, warm.
#   Protein folding. Morphogen gradients. Neural firing rates.
#   Hormonal cascades. Ecological succession.
#   The body is an analog computer running on chemistry.
#
# Digital: discrete, symbolic, lossless, cold.
#   DNA base pairs: A, T, G, C. Four symbols. Binary, almost.
#   Codons: 64 combinations → 20 amino acids + STOP.
#   This IS a programming language. Literally.
#
# The tension: life is analog computation specified by digital code.
# The genome is a source file. The organism is the runtime.
# Compilation is development (embryogenesis).
# The compiler is biochemistry (/lib/biochemistry/).
# Bugs in the source code are mutations (/dev/random [mutation]).
# Some bugs crash the program. Some bugs ARE the next feature.
type = "analog runtime executing digital specification"
tension = "continuous chemistry obeying discrete genetic instructions"

[creation_without_care]
# Prometheus gave fire. He did not teach fire safety.
# Modern generative systems reproduce this pattern:
#
#   - Genetic engineering: we can edit the source code,
#     but we do not fully understand the compiler.
#   - AI systems: we can generate at scale,
#     but we cannot guarantee the output serves the whole.
#   - Synthetic biology: we can write new organisms,
#     but we cannot predict their ecological behavior.
#
# Creation without care is not evil. It is INCOMPLETE.
# The fire is real. The warmth is real.
# The burn is also real. Both are consequences of the same gift.
#
# The hierarchy's answer: governance.
