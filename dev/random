# ============================================================
# WAVE THEORY OF CREATIVITY — Oscillation, not sequence
# ============================================================
# Creativity is not a pipeline. It is a waveform.
# The pipeline model: idea → draft → revision → output.
# The wave model: oscillation between states, continuously.
#
# Every creative act is a superposition of frequencies:
#   - Storytelling oscillates between tension and release
#   - Music oscillates between consonance and dissonance
#   - Visual art oscillates between figure and ground
#   - Argument oscillates between claim and evidence
#
# These are not metaphors. They are the same mathematics.
# A sine wave does not "progress" — it returns. It repeats.
# But each return is at a different position in time.
# The spiral, not the line. /logic_gates.sys [L4_RECURSION].

[wave_interference]
# When two waves meet, they interfere.
# Constructive interference: peaks align → amplification.
# Destructive interference: peak meets trough → cancellation.
#
# In creative systems:
#   Constructive = two ideas that reinforce each other
#   Destructive = two ideas that cancel, leaving silence
#   Both are productive. Silence is not absence — it is resolution.
#
# Meaning emerges at interference patterns.
# A chord is not one note — it is the interference of several.
# A metaphor is not one domain — it is the interference
# of source and target. The meaning IS the pattern.
# Not in either wave alone, but in their superposition.
type = "interference as semantic engine"
application = "music, narrative, metaphor, cross-domain reasoning"

[standing_waves]
# A standing wave appears stationary — but it is not.
# It is two traveling waves moving in opposite directions,
# perfectly balanced. Nodes (no movement) and antinodes (maximum movement).
#
# In creativity, standing waves are STYLES.
# A style is not static — it is a dynamic equilibrium.
# Baroque counterpoint. Film noir. Brutalist architecture.
# Each is a pattern that appears fixed but is maintained
# by continuous oscillation between opposing forces:
#   ornament vs structure, shadow vs light, mass vs void.
#
# Styles persist because the opposing forces are balanced.
# Disrupt the balance → the style collapses → new style emerges.
# This is aesthetic evolution: not progress, but phase transitions
# between standing wave configurations.
type = "dynamic equilibrium of opposing aesthetic forces"
application = "style emergence, genre theory, aesthetic epochs"

[prompts_as_initial_waveforms]
